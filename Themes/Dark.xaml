<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Color x:Key="BgDeep">#0D0D0F</Color>
  <Color x:Key="BgBase">#14151A</Color>
  <Color x:Key="BgPanel">#1C1D24</Color>
  <Color x:Key="BgCard">#23242E</Color>
  <Color x:Key="BgHover">#2A2B38</Color>
  <Color x:Key="Accent">#7B68EE</Color>
  <Color x:Key="AccentDim">#4B3F8E</Color>
  <Color x:Key="TextPrimary">#E8E8F0</Color>
  <Color x:Key="TextSecondary">#8888A8</Color>
  <Color x:Key="TextMuted">#505068</Color>
  <Color x:Key="Success">#4CAF82</Color>
  <Color x:Key="Warning">#E8A838</Color>
  <Color x:Key="Error">#E85858</Color>
  <Color x:Key="Border">#2C2D3A</Color>

  <SolidColorBrush x:Key="BrushBgDeep"    Color="{StaticResource BgDeep}"/>
  <SolidColorBrush x:Key="BrushBgBase"    Color="{StaticResource BgBase}"/>
  <SolidColorBrush x:Key="BrushBgPanel"   Color="{StaticResource BgPanel}"/>
  <SolidColorBrush x:Key="BrushBgCard"    Color="{StaticResource BgCard}"/>
  <SolidColorBrush x:Key="BrushBgHover"   Color="{StaticResource BgHover}"/>
  <SolidColorBrush x:Key="BrushAccent"    Color="{StaticResource Accent}"/>
  <SolidColorBrush x:Key="BrushAccentDim" Color="{StaticResource AccentDim}"/>
  <SolidColorBrush x:Key="BrushText"      Color="{StaticResource TextPrimary}"/>
  <SolidColorBrush x:Key="BrushTextSec"   Color="{StaticResource TextSecondary}"/>
  <SolidColorBrush x:Key="BrushTextMuted" Color="{StaticResource TextMuted}"/>
  <SolidColorBrush x:Key="BrushSuccess"   Color="{StaticResource Success}"/>
  <SolidColorBrush x:Key="BrushWarning"   Color="{StaticResource Warning}"/>
  <SolidColorBrush x:Key="BrushError"     Color="{StaticResource Error}"/>
  <SolidColorBrush x:Key="BrushBorder"    Color="{StaticResource Border}"/>

</ResourceDictionary>
