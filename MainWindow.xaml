<Window x:Class="UOGumpClassifier.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:UOGumpClassifier.ViewModels"
        Title="UO Paperdoll Workbench"
        Width="1400" Height="820"
        MinWidth="1100" MinHeight="640"
        Background="{StaticResource BrushBgBase}"
        WindowStyle="SingleBorderWindow">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="56"/>      <!-- Top bar -->
      <RowDefinition Height="*"/>       <!-- Main content -->
      <RowDefinition Height="64"/>      <!-- Bottom progress bar -->
    </Grid.RowDefinitions>

    <!-- ══ TOP BAR ══════════════════════════════════════════════════════════ -->
    <Border Grid.Row="0" Background="{StaticResource BrushBgPanel}"
            BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1">
      <Grid Margin="20,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Title -->
        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
          <TextBlock Text="UO Paperdoll Workbench" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource BrushText}"/>
          <TextBlock Text="Local AI-assisted gump and paperdoll classifier" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
          <TextBlock Text="{Binding InputFolder}" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
        </StackPanel>

        <!-- Toolbar buttons -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
          <Button Content="Load Folder"   Style="{StaticResource BtnGhost}"   Command="{Binding LoadFolderCommand}"/>
          <Button Content="Start Pass 1" Style="{StaticResource BtnPrimary}" Command="{Binding StartPass1Command}"/>
          <Button Content="Start Pass 2" Style="{StaticResource BtnGhost}"   Command="{Binding StartPass2Command}"/>
          <Button Content="Cancel"       Style="{StaticResource BtnDanger}"  Command="{Binding CancelCommand}"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ══ MAIN CONTENT ═════════════════════════════════════════════════════ -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="240" MinWidth="180"/>
        <ColumnDefinition Width="5"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="5"/>
        <ColumnDefinition Width="300" MinWidth="220"/>
      </Grid.ColumnDefinitions>

      <!-- ── LEFT: Queue ── -->
      <Border Grid.Column="0" Background="{StaticResource BrushBgPanel}"
              BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,1,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <Border Grid.Row="0" Padding="12,0" Background="{StaticResource BrushBgCard}">
            <TextBlock Text="Queue" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource BrushTextSec}"/>
          </Border>

          <ListBox Grid.Row="1" ItemsSource="{Binding Queue}"
                   SelectedItem="{Binding SelectedItem}"
                   SelectionChanged="QueueList_SelectionChanged"
                   VirtualizingPanel.IsVirtualizing="True"
                   Padding="4">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="56"/>
                  </Grid.ColumnDefinitions>

                  <!-- Thumbnail -->
                  <Image Grid.Column="0" Source="{Binding Thumbnail}" Width="40" Height="40"
                         Margin="0,0,6,0" RenderOptions.BitmapScalingMode="HighQuality"
                         VerticalAlignment="Center"
                         Background="Black"/>

                  <!-- File name + status -->
                  <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding FileName}" FontSize="12" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding StatusLabel}" FontSize="11"
                               Foreground="{StaticResource BrushTextMuted}"/>
                  </StackPanel>

                  <!-- Status badge -->
                  <Border Grid.Column="2" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right" VerticalAlignment="Center"
                          Background="{Binding StatusColor}" Opacity="0.85">
                    <TextBlock Text="{Binding StatusLabel}" FontSize="10" FontWeight="SemiBold"
                               Foreground="White"/>
                  </Border>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <!-- Splitter -->
      <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                    Background="{StaticResource BrushBorder}"/>

      <!-- ── CENTER: Image Preview ── -->
      <Border Grid.Column="2" Background="{StaticResource BrushBgDeep}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <Border Grid.Row="0" Padding="16,0" Background="{StaticResource BrushBgCard}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
              <TextBlock Text="Current Image" FontWeight="SemiBold" Foreground="{StaticResource BrushTextSec}"/>
              <TextBlock Text="&#x2022; black preview background expected" FontSize="11"
                         Foreground="{StaticResource BrushTextMuted}"/>
            </StackPanel>
          </Border>

          <Image Grid.Row="1" Source="{Binding CurrentImage}"
                 Stretch="Uniform" Margin="24"
                 RenderOptions.BitmapScalingMode="NearestNeighbor"
                 Background="Black"/>
        </Grid>
      </Border>

      <!-- Splitter -->
      <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch"
                    Background="{StaticResource BrushBorder}"/>

      <!-- ── RIGHT: Inspector ── -->
      <Border Grid.Column="4" Background="{StaticResource BrushBgPanel}"
              BorderBrush="{StaticResource BrushBorder}" BorderThickness="1,0,0,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
          <StackPanel Spacing="14">

            <!-- Inspector header -->
            <TextBlock Text="Inspector" FontSize="15" FontWeight="SemiBold"/>

            <!-- Phase -->
            <StackPanel Spacing="2">
              <TextBlock Text="Phase" Foreground="{StaticResource BrushTextMuted}" FontSize="11"/>
              <TextBlock Text="{Binding Phase}" FontSize="14" FontWeight="SemiBold"/>
            </StackPanel>

            <!-- Current file -->
            <StackPanel Spacing="2">
              <TextBlock Text="Current File" Foreground="{StaticResource BrushTextMuted}" FontSize="11"/>
              <TextBlock Text="{Binding CurrentFileName}" TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <!-- Classification -->
            <StackPanel Spacing="2">
              <TextBlock Text="Selected Classification" Foreground="{StaticResource BrushTextMuted}" FontSize="11"/>
              <TextBlock Text="{Binding SelectedClassification}" FontSize="14" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding SelectedStatus}" Foreground="{StaticResource BrushTextSec}" FontSize="11"/>
              <TextBlock Text="{Binding SelectedConfidence}" Foreground="{StaticResource BrushTextMuted}" FontSize="11"/>
            </StackPanel>

            <Separator/>

            <!-- Status Log -->
            <TextBlock Text="Status Log" Foreground="{StaticResource BrushTextMuted}" FontSize="11"/>
            <TextBox Text="{Binding StatusLog, Mode=OneWay}"
                     IsReadOnly="True" TextWrapping="Wrap"
                     FontSize="11" FontFamily="Consolas"
                     Background="{StaticResource BrushBgCard}"
                     Height="180"
                     VerticalScrollBarVisibility="Auto"
                     TextChanged="StatusLog_TextChanged"/>

            <Separator/>

            <!-- Raw JSON -->
            <TextBlock Text="Raw JSON" Foreground="{StaticResource BrushTextMuted}" FontSize="11"/>
            <TextBox Text="{Binding RawJson, Mode=OneWay}"
                     IsReadOnly="True" TextWrapping="Wrap"
                     FontSize="11" FontFamily="Consolas"
                     Background="{StaticResource BrushBgCard}"
                     Height="220"
                     VerticalScrollBarVisibility="Auto"/>

          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>

    <!-- ══ BOTTOM PROGRESS ═══════════════════════════════════════════════════ -->
    <Border Grid.Row="2" Background="{StaticResource BrushBgPanel}"
            BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0"
            Padding="20,0">
      <Grid VerticalAlignment="Center">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="6"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Labels -->
        <Grid Grid.Row="0">
          <TextBlock Text="Batch Progress" FontWeight="SemiBold" Foreground="{StaticResource BrushTextSec}"
                     HorizontalAlignment="Left" FontSize="12"/>
          <TextBlock Text="{Binding ProgressLabel}" HorizontalAlignment="Right"
                     Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
        </Grid>

        <!-- Progress bar -->
        <ProgressBar Grid.Row="1" Value="{Binding ProgressPercent}" Minimum="0" Maximum="100"
                     Margin="0,6,0,0"/>

        <!-- Percent + current file -->
        <Grid Grid.Row="2" Margin="0,4,0,0">
          <TextBlock Foreground="{StaticResource BrushTextMuted}" FontSize="11" HorizontalAlignment="Left">
            <Run Text="{Binding ProgressPercent, StringFormat={}{0:F1}}"/><Run Text="% complete"/>
          </TextBlock>
          <TextBlock Text="{Binding CurrentFileName}" FontSize="11"
                     Foreground="{StaticResource BrushTextMuted}" HorizontalAlignment="Right"
                     TextTrimming="CharacterEllipsis"/>
        </Grid>
      </Grid>
    </Border>

  </Grid>
</Window>
